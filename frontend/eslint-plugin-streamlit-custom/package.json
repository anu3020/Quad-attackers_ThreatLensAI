{
  "name": "eslint-plugin-streamlit-custom",
  "license": "Apache-2.0",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "format": "yarn run -T oxfmt --config ../.oxfmtrc.json './src/**/*.{js,ts,jsx,tsx}'",
    "formatCheck": "yarn run -T oxfmt --check --config ../.oxfmtrc.json './src/**/*.{js,ts,jsx,tsx}'",
    "lint": "eslint --cache --max-warnings 0 src",
    "test": "vitest run",
    "testWatch": "vitest",
    "typecheck": "tsc --noEmit",
    "typesync:ci": "typesync --dry=fail",
    "typesync": "typesync"
  },
  "devDependencies": {
    "@typescript-eslint/rule-tester": "^8.59.0",
    "@typescript-eslint/types": "^8.59.0",
    "@typescript-eslint/utils": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "typescript": "^6.0.3",
    "typesync": "^0.14.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@typescript-eslint/utils": "^8.59.0",
    "eslint": "^9.0.0"
  }
}
